# Dependencies
/node_modules

# Build output
/dist
/coverage
*.tsbuildinfo

# Local image storage (disk image store)
/var

# Filled-in deploy config (per environment); the .example templates are committed.
/scripts/deploy.*.env
!/scripts/deploy.*.env.example

# Terraform: local state, provider plugins, and filled-in vars (may hold secrets).
/terraform/.terraform
/terraform/.terraform.lock.hcl
/terraform/*.tfstate
/terraform/*.tfstate.*
/terraform/terraform.tfvars
/terraform/*.auto.tfvars

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
.idea
.vscode

# Runtime config
# config/config.local.json is committed with harmless local defaults only.
# If it ever needs to hold anything private, un-comment the line below and
# keep the real secrets out of the repo (production secrets live in GCP).
# config/config.local.json
