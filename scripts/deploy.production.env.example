# Production deploy config. Copy this to `deploy.production.env` (gitignored) and
# fill in the real values, then run `npm run deploy:production`.
#
# These are the values the repeatable deploy needs. The non-secret ones here
# should match what the one-time setup set on the Cloud Run service (see
# DEPLOY.md); the database password is fetched from Secret Manager at deploy
# time, never stored here.

# --- GCP project / region -------------------------------------------------
GCP_PROJECT=fed-tht
GCP_REGION=us-central1

# --- Backend (Cloud Run) --------------------------------------------------
BACKEND_SERVICE=fed-tht-api
# The address the frontend will call — the Cloud Run URL or your custom domain.
BACKEND_HOSTNAME=https://api.fed-tht.example.com

# --- Database (Postgres on a Compute Engine VM) ---------------------------
# The VM the migration step reaches over an IAP tunnel. The running backend
# reaches the same VM by its internal IP (set on the Cloud Run service).
DB_VM_NAME=fed-tht-db
DB_VM_ZONE=us-central1-a
DB_NAME=fedtht
DB_USER=fedtht
# Secret Manager secret NAME holding the DB password (fetched at deploy time).
DB_PASSWORD_SECRET=fed-tht-db-password

# --- Frontend (Firebase Hosting) ------------------------------------------
FIREBASE_PROJECT=fed-tht

# --- Production runtime config (also set on the Cloud Run service) ---------
# Present here because the migration step loads the same production config.
SERVICE_NAME=fed-tht-label-check
PORT=8080
GCS_BUCKET=fed-tht-images
# The frontend origin the backend accepts (CORS) — the Firebase Hosting address.
CORS_ORIGINS=https://fed-tht.web.app
